{
  "name": "checkout-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "serve": "nest start",
    "serve:dev": "nest start --watch",
    "serve:debug": "nest start --debug --watch",
    "serve:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "test": "exit 0",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:integration": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.60.1",
    "@opentelemetry/core": "^2.1.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.202.0",
    "@opentelemetry/id-generator-aws-xray": "^2.0.0",
    "@opentelemetry/resource-detector-aws": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.202.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.9.2",
    "nestjs-otel": "^7.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.3",
    "@types/express": "^5.0.3",
    "@types/jest": "30.0.0",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "jest": "30.0.4",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.1",
    "testcontainers": "^11.0.3",
    "ts-jest": "29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "resolutions": {
    "cross-spawn@npm:^7.0.3": "7.0.6",
    "glob@npm:^10.0.0": "10.5.0",
    "glob@npm:^11.0.0": "11.1.0",
    "lodash@npm:4.17.21": "4.18.0",
    "lodash@npm:^4.17.15": "4.18.0",
    "lodash@npm:^4.17.21": "4.18.0",
    "minimatch@npm:^10.1.1": "10.2.3",
    "minimatch@npm:^3.0.4": "3.1.4",
    "minimatch@npm:^3.1.1": "3.1.4",
    "minimatch@npm:^3.1.2": "3.1.4",
    "minimatch@npm:^5.0.1": "5.1.8",
    "minimatch@npm:^5.1.0": "5.1.8",
    "minimatch@npm:^9.0.4": "9.0.7",
    "multer@npm:2.0.1": "2.1.1",
    "path-to-regexp@npm:8.2.0": "8.4.0",
    "protobufjs@npm:^7.2.5": "7.5.5",
    "protobufjs@npm:^7.3.0": "7.5.5",
    "protobufjs@npm:^7.3.2": "7.5.5",
    "systeminformation@npm:5.23.8": "5.31.0",
    "tar@npm:^7.5.2": "7.5.11"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@4.11.0"
}
